<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- التطبيق يستخدم HTTPS/TLS من نظام iOS فقط (تشفير معفى) — يتخطّى سؤال
	     Export Compliance في كل بناء جديد. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- App Tracking Transparency — required by TikTok SDK for IDFA-based
	     attribution. Shown once on first launch. -->
	<key>NSUserTrackingUsageDescription</key>
	<string>نستخدم بياناتك لتحسين العروض والإعلانات المناسبة لك. We use your data to deliver more relevant offers and ads.</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Uellow</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>uellow</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Google Sign-In: the iOS OAuth client id (from google-services.json,
	     client_type 2 / bundle com.uellow.app). Without GIDClientID the
	     google_sign_in plugin crashes on iOS. -->
	<key>GIDClientID</key>
	<string>50540776966-48kgig4ojqik90lmrc42uv0n7n9b06ar.apps.googleusercontent.com</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.uellow.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>uellow</string>
			</array>
		</dict>
		<!-- Google OAuth callback = the REVERSED iOS client id. -->
		<dict>
			<key>CFBundleURLName</key>
			<string>google-signin</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.50540776966-48kgig4ojqik90lmrc42uv0n7n9b06ar</string>
			</array>
		</dict>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>NSUserActivityTypes</key>
	<array>
		<string>NSUserActivityTypeBrowsingWeb</string>
	</array>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Uellow uses your location to set delivery addresses on the map and to track orders to your door.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Uellow uses your location to set delivery addresses on the map and to track orders to your door.</string>
	<key>NSCameraUsageDescription</key>
	<string>Uellow uses the camera so you can upload a landmark photo for your delivery address, your profile photo, and try-on photos.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Uellow needs access to your photo library so you can upload images for your address, profile, and try-on.</string>
</dict>
</plist>
